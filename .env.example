# Copy this file to .env and fill in your own values. .env is git-ignored -
# never commit real credentials.

# Your personal login for the ActiveLocals admin portal
ACTIVELOCALS_EMAIL=
ACTIVELOCALS_PASSWORD=

# Optional. Only needed if you run test_single_event.py / batch_create_events.py
# directly without --event-json-file / --research-file (i.e. NOT via the Claude
# Code skill, which researches clubs itself and needs no API key at all).
ANTHROPIC_API_KEY=
